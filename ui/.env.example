# MapTiler API Configuration
# Copy this file to .env and fill in your MapTiler API key
# Get your API key from https://cloud.maptiler.com/

# MapTiler API Key (required for MapTiler tiles)
VITE_MAPTILER_API_KEY=your_maptiler_api_key_here

# MapTiler Style (optional, defaults to openstreetmap)
# Options: openstreetmap, streets-v2, dark-v2, satellite, etc.
VITE_MAPTILER_STYLE=openstreetmap
