Checks: "-*,\
modernize-use-auto"
WarningsAsErrors: '*'
HeaderFilterRegex: '^${RELATIVE_SOURCE_DIR}(src|include|exe|test)/'
UseColor: true
CheckOptions:
  - key:             modernize-use-auto.MinTypeNameLength
    value:           '5'
  - key:             modernize-use-auto.RemoveStars
    value:           '0'
